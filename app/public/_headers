# index.html — always revalidate so users pick up new deployments immediately
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/404.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed JS/CSS assets — safe to cache long-term (filename changes on each build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
