{
  "name": "morechard-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply morechard",
    "db:migrate:local": "wrangler d1 migrations apply morechard --local",
    "db:seed": "wrangler d1 execute morechard --local --file=./seed.sql",
    "db:reset": "wrangler d1 execute morechard --local --file=./reset.sql",
    "test": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.79.0"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.47.0"
  }
}
