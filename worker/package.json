{
  "name": "moneysteps-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply moneysteps",
    "db:migrate:local": "wrangler d1 migrations apply moneysteps --local",
    "db:seed": "wrangler d1 execute moneysteps --local --file=./seed.sql",
    "db:reset": "wrangler d1 execute moneysteps --local --file=./reset.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.2",
    "wrangler": "^4.79.0"
  }
}
